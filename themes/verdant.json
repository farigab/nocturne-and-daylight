  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#2a3828", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#a8d878" } },
    { "scope": ["constant.character.escape", "string.regexp"], "settings": { "foreground": "#78c8b0" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#e8c87a" } },
    { "scope": ["constant.language"], "settings": { "foreground": "#98b8e8" } },
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#6ab87a", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#7ac87a", "fontStyle": "" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#78c8b0" } },
    { "scope": ["entity.name.type", "entity.name.class", "entity.name.interface", "entity.name.enum", "support.class"], "settings": { "foreground": "#98b8e8" } },
    { "scope": ["variable"], "settings": { "foreground": "#b8d0b4" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#a0c0a0", "fontStyle": "italic" } },
    { "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#6ab87a", "fontStyle": "italic" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#6ab87a" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#e8c87a", "fontStyle": "italic" } },
    { "scope": ["meta.decorator", "storage.type.annotation", "punctuation.definition.annotation"], "settings": { "foreground": "#e8c87a", "fontStyle": "italic" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#486848" } },
    { "scope": ["support.type.property-name.css"], "settings": { "foreground": "#6ab87a" } },
    { "scope": ["support.type.property-name.json"], "settings": { "foreground": "#6ab87a" } },
    { "scope": ["invalid"], "settings": { "foreground": "#c07868", "fontStyle": "underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#98b8e8" },
    "interface": { "foreground": "#98b8e8", "italic": true },
    "enum": { "foreground": "#98b8e8" },
    "type": { "foreground": "#a8c8f0" },
    "function": { "foreground": "#78c8b0" },
    "method": { "foreground": "#78c8b0" },
    "property": { "foreground": "#a0c0a0" },
    "variable": { "foreground": "#b8d0b4" },
    "parameter": { "foreground": "#a0c0a0", "italic": true },
    "decorator": { "foreground": "#e8c87a", "italic": true },
    "keyword": { "foreground": "#6ab87a", "italic": true },
    "string": { "foreground": "#a8d878" },
    "number": { "foreground": "#e8c87a" },
    "comment": { "foreground": "#2a3828", "italic": true }
  }
}
