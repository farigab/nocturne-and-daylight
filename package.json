{
  "name": "nocturne-and-daylight",
  "displayName": "Nocturne & Daylight",
  "description": "A curated collection of 8 eye-friendly VS Code themes — 4 dark and 4 light. Features Catppuccin, Rosé Pine, Tokyo Night, Gruvbox Material, GitHub Light, and Flexoki. Designed for readability and long coding sessions.",
  "version": "1.0.2",
  "publisher": "farigab",
  "license": "MIT",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "homepage": "https://github.com/farigab/nocturne-and-daylight",
  "bugs": {
    "url": "https://github.com/farigab/nocturne-and-daylight/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "catppuccin",
    "rose pine",
    "tokyo night",
    "gruvbox",
    "gruvbox material",
    "flexoki",
    "github light",
    "eye friendly",
    "minimal",
    "nocturne",
    "daylight"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/farigab/nocturne-and-daylight"
  },
  "contributes": {
    "themes": [
      {
        "label": "Catppuccin Mocha",
        "uiTheme": "vs-dark",
        "path": "./themes/catppuccin-mocha.json"
      },
      {
        "label": "Rosé Pine",
        "uiTheme": "vs-dark",
        "path": "./themes/rose-pine.json"
      },
      {
        "label": "Tokyo Night",
        "uiTheme": "vs-dark",
        "path": "./themes/tokyo-night.json"
      },
      {
        "label": "Gruvbox Material",
        "uiTheme": "vs-dark",
        "path": "./themes/gruvbox-material.json"
      },
      {
        "label": "Catppuccin Latte",
        "uiTheme": "vs",
        "path": "./themes/catppuccin-latte.json"
      },
      {
        "label": "Rosé Pine Dawn",
        "uiTheme": "vs",
        "path": "./themes/rose-pine-dawn.json"
      },
      {
        "label": "GitHub Light Default",
        "uiTheme": "vs",
        "path": "./themes/github-light.json"
      },
      {
        "label": "Flexoki Light",
        "uiTheme": "vs",
        "path": "./themes/flexoki-light.json"
      }
    ]
  },
  "scripts": {
    "build": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
