    "quickInput.foreground": "#c5cde8",
    "focusBorder": "#3e4460",
    "foreground": "#a0aac8",
    "badge.background": "#3a5580",
    "badge.foreground": "#dde4f5",
    "gitDecoration.addedResourceForeground": "#8cc88e",
    "gitDecoration.modifiedResourceForeground": "#c8b87a",
    "gitDecoration.deletedResourceForeground": "#c87878",
    "gitDecoration.untrackedResourceForeground": "#8cc88e",
    "gitDecoration.ignoredResourceForeground": "#454c6a",
    "diffEditor.insertedTextBackground": "#2a4230",
    "diffEditor.removedTextBackground": "#42262a",
    "minimap.background": "#171a28",
    "minimap.selectionHighlight": "#3a4263"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#4e566e", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#9ac89a" } },
    { "scope": ["constant.character.escape", "string.regexp"], "settings": { "foreground": "#7ecfcf" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#d4a47a" } },
    { "scope": ["constant.language"], "settings": { "foreground": "#c8a0c8" } },
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#8aaede", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#7eb5f4", "fontStyle": "" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#7ecfcf" } },
    { "scope": ["entity.name.type", "entity.name.class", "entity.name.interface", "entity.name.enum", "support.class"], "settings": { "foreground": "#b8a0d8" } },
    { "scope": ["variable"], "settings": { "foreground": "#c5cde8" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#b8c0dc", "fontStyle": "italic" } },
    { "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#8aaede", "fontStyle": "italic" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#8aaede" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#c8b87a", "fontStyle": "italic" } },
    { "scope": ["meta.decorator", "storage.type.annotation", "punctuation.definition.annotation"], "settings": { "foreground": "#c8b87a", "fontStyle": "italic" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#6a7898" } },
    { "scope": ["support.type.property-name.css"], "settings": { "foreground": "#8aaede" } },
    { "scope": ["support.type.property-name.json"], "settings": { "foreground": "#8aaede" } },
    { "scope": ["invalid"], "settings": { "foreground": "#c87878", "fontStyle": "underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#b8a0d8" },
    "interface": { "foreground": "#b8a0d8", "italic": true },
    "enum": { "foreground": "#b8a0d8" },
    "type": { "foreground": "#c0a8e0" },
    "function": { "foreground": "#7ecfcf" },
    "method": { "foreground": "#7ecfcf" },
    "property": { "foreground": "#bcc4de" },
    "variable": { "foreground": "#c5cde8" },
    "parameter": { "foreground": "#b8c0dc", "italic": true },
    "decorator": { "foreground": "#c8b87a", "italic": true },
    "keyword": { "foreground": "#8aaede", "italic": true },
    "string": { "foreground": "#9ac89a" },
    "number": { "foreground": "#d4a47a" },
    "comment": { "foreground": "#4e566e", "italic": true }
  }
}
