  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#8c8fa1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "keyword, storage.type, storage.modifier",
      "settings": {
        "foreground": "#8839ef"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#04a5e5"
      }
    },
    {
      "scope": "string, string.template",
      "settings": {
        "foreground": "#40a02b"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#179299"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#fe640b"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#fe640b"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#179299"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#4c4f69"
      }
    },
    {
      "scope": "variable.language",
      "settings": {
        "foreground": "#8839ef",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "entity.name.function, support.function",
      "settings": {
        "foreground": "#1e66f5"
      }
    },
    {
      "scope": "entity.name.type, entity.name.class, support.class",
      "settings": {
        "foreground": "#df8e1d"
      }
    },
    {
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#d20f39"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#fe640b"
      }
    },
    {
      "scope": "support.type",
      "settings": {
        "foreground": "#179299"
      }
    },
    {
      "scope": "meta.decorator, punctuation.decorator",
      "settings": {
        "foreground": "#1e66f5"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#5c5f77"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#d20f39"
      }
    }
  ]
}
