  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#4a3f38", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#a8c87a" } },
    { "scope": ["constant.character.escape", "string.regexp"], "settings": { "foreground": "#7ac8b8" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#e8785a" } },
    { "scope": ["constant.language"], "settings": { "foreground": "#c87a9a" } },
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#e8954a", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#d4a870", "fontStyle": "" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#e8c87a" } },
    { "scope": ["entity.name.type", "entity.name.class", "entity.name.interface", "entity.name.enum", "support.class"], "settings": { "foreground": "#c87a9a" } },
    { "scope": ["variable"], "settings": { "foreground": "#d4b896" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#c0a882", "fontStyle": "italic" } },
    { "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#e8954a", "fontStyle": "italic" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#e8954a" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#e8c87a", "fontStyle": "italic" } },
    { "scope": ["meta.decorator", "storage.type.annotation", "punctuation.definition.annotation"], "settings": { "foreground": "#7ac8b8", "fontStyle": "italic" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#6a5238" } },
    { "scope": ["support.type.property-name.css"], "settings": { "foreground": "#e8954a" } },
    { "scope": ["support.type.property-name.json"], "settings": { "foreground": "#e8954a" } },
    { "scope": ["invalid"], "settings": { "foreground": "#d87060", "fontStyle": "underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#c87a9a" },
    "interface": { "foreground": "#c87a9a", "italic": true },
    "enum": { "foreground": "#c87a9a" },
    "type": { "foreground": "#d890b0" },
    "function": { "foreground": "#e8c87a" },
    "method": { "foreground": "#e8c87a" },
    "property": { "foreground": "#c8a878" },
    "variable": { "foreground": "#d4b896" },
    "parameter": { "foreground": "#c0a882", "italic": true },
    "decorator": { "foreground": "#7ac8b8", "italic": true },
    "keyword": { "foreground": "#e8954a", "italic": true },
    "string": { "foreground": "#a8c87a" },
    "number": { "foreground": "#e8785a" },
    "comment": { "foreground": "#4a3f38", "italic": true }
  }
}
