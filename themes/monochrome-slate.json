    "foreground": "#909090",
    "badge.background": "#383848",
    "badge.foreground": "#e0e0e8",
    "gitDecoration.addedResourceForeground": "#b8c8b8",
    "gitDecoration.modifiedResourceForeground": "#b8a878",
    "gitDecoration.deletedResourceForeground": "#b87878",
    "gitDecoration.untrackedResourceForeground": "#b8c8b8",
    "gitDecoration.ignoredResourceForeground": "#383838",
    "diffEditor.insertedTextBackground": "#202820",
    "diffEditor.removedTextBackground": "#281e1e",
    "minimap.background": "#141414",
    "minimap.selectionHighlight": "#303030"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#383838", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#b8c8b8" } },
    { "scope": ["constant.character.escape", "string.regexp"], "settings": { "foreground": "#98b8b8" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#c8b898" } },
    { "scope": ["constant.language"], "settings": { "foreground": "#b8b8d0" } },
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#9898b8", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#a8a8c0", "fontStyle": "" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#d8d8d8" } },
    { "scope": ["entity.name.type", "entity.name.class", "entity.name.interface", "entity.name.enum", "support.class"], "settings": { "foreground": "#b8b8d0" } },
    { "scope": ["variable"], "settings": { "foreground": "#c8c8c8" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#b8b8b8", "fontStyle": "italic" } },
    { "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#9898b8", "fontStyle": "italic" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#9898b8" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#a8a8a8", "fontStyle": "italic" } },
    { "scope": ["meta.decorator", "storage.type.annotation", "punctuation.definition.annotation"], "settings": { "foreground": "#b8a878", "fontStyle": "italic" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#505050" } },
    { "scope": ["support.type.property-name.css"], "settings": { "foreground": "#9898b8" } },
    { "scope": ["support.type.property-name.json"], "settings": { "foreground": "#9898b8" } },
    { "scope": ["invalid"], "settings": { "foreground": "#b87878", "fontStyle": "underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#b8b8d0" },
    "interface": { "foreground": "#b8b8d0", "italic": true },
    "enum": { "foreground": "#b8b8d0" },
    "type": { "foreground": "#c0c0d8" },
    "function": { "foreground": "#d8d8d8" },
    "method": { "foreground": "#d8d8d8" },
    "property": { "foreground": "#b8b8b8" },
    "variable": { "foreground": "#c8c8c8" },
    "parameter": { "foreground": "#b8b8b8", "italic": true },
    "decorator": { "foreground": "#b8a878", "italic": true },
    "keyword": { "foreground": "#9898b8", "italic": true },
    "string": { "foreground": "#b8c8b8" },
    "number": { "foreground": "#c8b898" },
    "comment": { "foreground": "#383838", "italic": true }
  }
}
