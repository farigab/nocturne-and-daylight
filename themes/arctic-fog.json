  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#283040", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#78c8b8" } },
    { "scope": ["constant.character.escape", "string.regexp"], "settings": { "foreground": "#98c8e8" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#78b8c8" } },
    { "scope": ["constant.language"], "settings": { "foreground": "#a898d8" } },
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#5a9ed8", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#6ab0e0", "fontStyle": "" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#98c8e8" } },
    { "scope": ["entity.name.type", "entity.name.class", "entity.name.interface", "entity.name.enum", "support.class"], "settings": { "foreground": "#a898d8" } },
    { "scope": ["variable"], "settings": { "foreground": "#a8c8e8" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#90b8d8", "fontStyle": "italic" } },
    { "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#5a9ed8", "fontStyle": "italic" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#5a9ed8" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#78c8b8", "fontStyle": "italic" } },
    { "scope": ["meta.decorator", "storage.type.annotation", "punctuation.definition.annotation"], "settings": { "foreground": "#c0a860", "fontStyle": "italic" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#3a5068" } },
    { "scope": ["support.type.property-name.css"], "settings": { "foreground": "#5a9ed8" } },
    { "scope": ["support.type.property-name.json"], "settings": { "foreground": "#5a9ed8" } },
    { "scope": ["invalid"], "settings": { "foreground": "#c07878", "fontStyle": "underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#a898d8" },
    "interface": { "foreground": "#a898d8", "italic": true },
    "enum": { "foreground": "#a898d8" },
    "type": { "foreground": "#b8a8e0" },
    "function": { "foreground": "#98c8e8" },
    "method": { "foreground": "#98c8e8" },
    "property": { "foreground": "#90b8d8" },
    "variable": { "foreground": "#a8c8e8" },
    "parameter": { "foreground": "#90b8d8", "italic": true },
    "decorator": { "foreground": "#c0a860", "italic": true },
    "keyword": { "foreground": "#5a9ed8", "italic": true },
    "string": { "foreground": "#78c8b8" },
    "number": { "foreground": "#78b8c8" },
    "comment": { "foreground": "#283040", "italic": true }
  }
}
