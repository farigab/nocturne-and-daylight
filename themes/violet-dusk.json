  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#2e2040", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#88c8a8" } },
    { "scope": ["constant.character.escape", "string.regexp"], "settings": { "foreground": "#88b8d8" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#e8a888" } },
    { "scope": ["constant.language"], "settings": { "foreground": "#c898c8" } },
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#a888d8", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#b898e0", "fontStyle": "" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#c898c8" } },
    { "scope": ["entity.name.type", "entity.name.class", "entity.name.interface", "entity.name.enum", "support.class"], "settings": { "foreground": "#88a8e8" } },
    { "scope": ["variable"], "settings": { "foreground": "#c8bce8" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#b8a8d8", "fontStyle": "italic" } },
    { "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#a888d8", "fontStyle": "italic" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#a888d8" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#c8a870", "fontStyle": "italic" } },
    { "scope": ["meta.decorator", "storage.type.annotation", "punctuation.definition.annotation"], "settings": { "foreground": "#c8a870", "fontStyle": "italic" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#5a4880" } },
    { "scope": ["support.type.property-name.css"], "settings": { "foreground": "#a888d8" } },
    { "scope": ["support.type.property-name.json"], "settings": { "foreground": "#a888d8" } },
    { "scope": ["invalid"], "settings": { "foreground": "#c07888", "fontStyle": "underline" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#88a8e8" },
    "interface": { "foreground": "#88a8e8", "italic": true },
    "enum": { "foreground": "#88a8e8" },
    "type": { "foreground": "#98b8f0" },
    "function": { "foreground": "#c898c8" },
    "method": { "foreground": "#c898c8" },
    "property": { "foreground": "#b8a8d8" },
    "variable": { "foreground": "#c8bce8" },
    "parameter": { "foreground": "#b8a8d8", "italic": true },
    "decorator": { "foreground": "#c8a870", "italic": true },
    "keyword": { "foreground": "#a888d8", "italic": true },
    "string": { "foreground": "#88c8a8" },
    "number": { "foreground": "#e8a888" },
    "comment": { "foreground": "#2e2040", "italic": true }
  }
}
